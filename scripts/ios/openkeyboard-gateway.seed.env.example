# Copy this file to .agent/local-seeds/openkeyboard-gateway.env.
# Never commit the real seed file. .agent/local-seeds/ is ignored.
# Used only by scripts/ios/seed-simulator-gateway-config.sh for explicit
# local simulator actual-keyboard testing with real gateway data.

OPEN_KEYBOARD_SIMULATOR_GATEWAY_URL=https://your-gateway.example
OPEN_KEYBOARD_SIMULATOR_API_KEY=replace-with-real-key-locally
OPEN_KEYBOARD_SIMULATOR_MODEL=your-model-name
